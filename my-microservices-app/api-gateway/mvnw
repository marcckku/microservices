#!/bin/sh
set -e

MAVEN_OPTS="-Xmx1024m -XX:MaxPermSize=256m"
MVNW_HOME="$(cd "$(dirname "$0")/.." && pwd)"
MVN_CMD="$MVNW_HOME/.mvn/wrapper/maven-wrapper.jar"

if [ ! -f "$MVN_CMD" ]; then
  echo "Error: Maven wrapper jar not found. Please run 'mvn -N io.takari:maven:wrapper' to generate it."
  exit 1
fi

exec java $MAVEN_OPTS -cp "$MVN_CMD" org.apache.maven.wrapper.MavenWrapperMain "$@"