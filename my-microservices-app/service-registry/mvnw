#!/bin/sh
set -e

# Maven wrapper script for Unix-based systems

MAVEN_VERSION=3.8.6
MVNW_HOME=$(cd "$(dirname "$0")/.." && pwd)
MAVEN_OPTS="-Xmx1024m -XX:MaxPermSize=256m"

if [ -z "$M2_HOME" ]; then
  M2_HOME="$MVNW_HOME/.m2"
fi

if [ ! -d "$M2_HOME" ]; then
  mkdir -p "$M2_HOME"
fi

if [ -f "$MVNW_HOME/.mvn/wrapper/maven-wrapper.jar" ]; then
  exec java $MAVEN_OPTS -cp "$MVNW_HOME/.mvn/wrapper/maven-wrapper.jar" org.apache.maven.wrapper.MavenWrapperMain "$@"
else
  echo "Maven wrapper jar not found. Please run 'mvn -N io.takari:maven:wrapper' to generate it."
  exit 1
fi